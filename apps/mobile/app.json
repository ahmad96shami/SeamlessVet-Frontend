{
  "expo": {
    "name": "SeamlessVet Field",
    "slug": "vet-mobile",
    "scheme": "vetmobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.seamlessvet.mobile"
    },
    "android": {
      "package": "com.seamlessvet.mobile"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-localization", "expo-updates"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
