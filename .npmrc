strict-peer-dependencies=false

# Expo + pnpm: Metro is built around Node's classic flat resolver and can't
# navigate pnpm's nested symlink store the way Vite/Webpack do. The supported
# pattern for Expo monorepos on pnpm is a hoisted layout, so every transitive
# (invariant, nullthrows, fast-base64-decode, etc.) ends up at workspace
# node_modules where Metro's resolver can find it. The web app is unaffected.
node-linker=hoisted
